---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { getCollection } from "astro:content";

export const prerender = false;

// 权限检查
if (Astro.cookies.get('admin_token')?.value !== 'authenticated') {
  return Astro.redirect('/admin/login/');
}

const posts = await getCollection("posts");
const moments = await getCollection("moments");

const stats = [
  { label: "全部文章", value: posts.length, icon: "material-symbols:article-outline-rounded", color: "blue" },
  { label: "全部动态", value: moments.length, icon: "material-symbols:camera-roll-outline-rounded", color: "green" },
];
---

<AdminLayout title="仪表盘">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-[var(--text-color)]">欢迎回来，管理员</h1>
    <p class="text-[var(--content-meta)] mt-2">在这里管理你的 Firefly 博客内容。</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
    {stats.map(stat => (
      <div class="card-base p-6 rounded-2xl flex items-center gap-4">
        <div class={`w-12 h-12 rounded-xl bg-${stat.color}-500/10 text-${stat.color}-500 flex items-center justify-center`}>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-text"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
        </div>
        <div>
          <p class="text-sm text-[var(--content-meta)]">{stat.label}</p>
          <p class="text-2xl font-bold text-[var(--text-color)]">{stat.value}</p>
        </div>
      </div>
    ))}
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <div class="card-base p-6 rounded-2xl">
      <h2 class="text-xl font-bold mb-6 flex items-center gap-2 text-[var(--text-color)]">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-zap"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        快速操作
      </h2>
      <div class="grid grid-cols-2 gap-4">
        <a href="/admin/moments/" class="flex flex-col items-center justify-center p-6 rounded-xl border border-[var(--border-color)] hover:border-[var(--primary)] hover:bg-[var(--primary)]/5 transition-all group">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plus-circle text-[var(--content-meta)] group-hover:text-[var(--primary)] mb-3"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="16"/><line x1="8" x2="16" y1="12" y2="12"/></svg>
          <span class="font-bold text-[var(--text-color)]">发布新动态</span>
        </a>
        <a href="/admin/posts/" class="flex flex-col items-center justify-center p-6 rounded-xl border border-[var(--border-color)] hover:border-[var(--primary)] hover:bg-[var(--primary)]/5 transition-all group">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plus-square text-[var(--content-meta)] group-hover:text-[var(--primary)] mb-3"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M12 8v8"/><path d="M8 12h8"/></svg>
          <span class="font-bold text-[var(--text-color)]">发布新文章</span>
        </a>
      </div>
    </div>
  </div>
</AdminLayout>
