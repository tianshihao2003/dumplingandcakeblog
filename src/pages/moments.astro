---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getCollection } from "astro:content";
import MomentCard from "@/components/moments/MomentCard.astro";

const moments = await getCollection("moments");
// 按发布时间降序排序
const sortedMoments = moments.sort(
  (a, b) => b.data.published.getTime() - a.data.published.getTime()
);
---

<MainGridLayout title="日常动态" description="记录生活中的点点滴滴">
  <div class="flex flex-col w-full relative min-h-[50vh]">
    <!-- 密码锁屏遮罩 -->
    <div id="moments-lock-screen" class="absolute inset-0 z-50 flex flex-col items-center justify-center bg-[var(--card-bg)] rounded-[var(--radius-large)] transition-opacity duration-500 backdrop-blur-md">
      <div class="flex flex-col items-center p-8 max-w-sm w-full">
        <div class="w-16 h-16 rounded-full bg-[var(--primary)]/10 text-[var(--primary)] flex items-center justify-center mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-lock"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <h2 class="text-2xl font-bold mb-2 text-[var(--text-color)]">私密空间</h2>
        <p class="text-[var(--content-meta)] text-sm mb-6 text-center">这里记录了一些私人日常，请输入我的生日。</p>
        
        <form id="moments-password-form" class="w-full flex flex-col gap-4">
          <div class="relative">
            <input 
              type="password" 
              id="moments-password-input" 
              placeholder="请输入密码" 
              class="w-full px-4 py-3 rounded-xl bg-[var(--card-bg)] border border-[var(--border-color)] focus:border-[var(--primary)] focus:ring-2 focus:ring-[var(--primary)]/20 outline-none transition-all text-center text-[var(--text-color)]"
              required
            />
            <div id="password-error" class="absolute -bottom-6 left-0 right-0 text-red-500 text-xs text-center hidden">密码错误，请重试</div>
          </div>
          <button 
            type="submit" 
            class="w-full py-3 mt-2 rounded-xl bg-[var(--primary)] text-white font-bold transition-transform hover:scale-[0.98] active:scale-95"
          >
            进入空间
          </button>
        </form>
      </div>
    </div>

    <!-- 动态内容区 (默认隐藏) -->
    <div id="moments-content" class="w-full opacity-0 pointer-events-none transition-opacity duration-500 h-0 overflow-hidden">
      <!-- 头部横幅或标题区 -->
      <div class="card-base w-full rounded-[var(--radius-large)] overflow-hidden relative p-6 mb-6 flex flex-col items-center justify-center text-center py-10">
        <h1 class="text-3xl font-bold text-[var(--primary)] mb-2">日常动态</h1>
        <p class="text-[var(--content-meta)]">记录生活中的点点滴滴，像风一样自由。</p>
      </div>

      <!-- 动态列表 -->
      <div class="moments-list relative w-full">
        {sortedMoments.length > 0 ? (
          <div class="relative z-10 flex flex-col gap-2">
            {sortedMoments.map((moment, index) => (
              <div class="onload-animation" style={`animation-delay: calc(var(--content-delay) + ${index * 100}ms)`}>
                <MomentCard moment={moment} />
              </div>
            ))}
          </div>
        ) : (
          <div class="card-base w-full rounded-[var(--radius-large)] p-10 text-center text-[var(--content-meta)]">
            还没有发布任何动态哦~
          </div>
        )}
      </div>

      <!-- 评论区 -->
      <div class="card-base w-full rounded-[var(--radius-large)] overflow-hidden relative p-6 mt-6 onload-animation" style="animation-delay: calc(var(--content-delay) + 500ms);">
        <h2 class="text-xl font-bold text-[var(--text-color)] mb-4 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-message-square"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          留言互动
        </h2>
        <div id="waline-comment" class="w-full"></div>
      </div>
    </div>
  </div>
</MainGridLayout>

<script>
  // @ts-nocheck
  import '@waline/client/waline.css';
  import { init } from '@waline/client';

  // 密码设置 (你可以修改这里的密码)
  const CORRECT_PASSWORD = "0824";
  const AUTH_KEY = "moments_authenticated";

  // 获取 DOM 元素
  const lockScreen = document.getElementById("moments-lock-screen");
  const contentArea = document.getElementById("moments-content");
  const passwordForm = document.getElementById("moments-password-form");
  const passwordInput = document.getElementById("moments-password-input") as HTMLInputElement;
  const errorMsg = document.getElementById("password-error");

  // 解锁函数
  function unlock() {
    if (lockScreen && contentArea) {
      lockScreen.style.opacity = "0";
      setTimeout(() => {
        lockScreen.style.display = "none";
        contentArea.classList.remove("opacity-0", "pointer-events-none", "h-0", "overflow-hidden");
        contentArea.classList.add("opacity-100");
        
        // 解锁后初始化评论系统
        initWaline();
      }, 500);
    }
  }

  // 初始化 Waline
  function initWaline() {
    // 确保容器存在且没有被初始化过
    const container = document.getElementById('waline-comment');
    if (container && !container.hasChildNodes()) {
      init({
        el: '#waline-comment',
        serverURL: 'https://co.tsh520.cn', // 从你的配置中读取的地址
        lang: 'zh-CN',
        path: '/moments/', // 指定固定路径，防止带参数导致评论分散
        reaction: true,
      });
    }
  }

  // 页面加载时检查是否已经验证过
  document.addEventListener("DOMContentLoaded", () => {
    // 使用 sessionStorage，这样关闭浏览器标签页后密码会失效，更安全
    if (sessionStorage.getItem(AUTH_KEY) === "true") {
      unlock();
    }
  });

  // 处理表单提交
  if (passwordForm) {
    passwordForm.addEventListener("submit", (e) => {
      e.preventDefault();
      const inputVal = passwordInput?.value;

      if (inputVal === CORRECT_PASSWORD) {
        // 密码正确
        if (errorMsg) errorMsg.classList.add("hidden");
        sessionStorage.setItem(AUTH_KEY, "true");
        unlock();
      } else {
        // 密码错误
        if (errorMsg) {
          errorMsg.classList.remove("hidden");
          // 震动动画提示
          passwordInput?.classList.add("animate-shake");
          setTimeout(() => {
            passwordInput?.classList.remove("animate-shake");
          }, 500);
        }
        if (passwordInput) passwordInput.value = "";
      }
    });
  }
</script>

<style>
  /* 密码错误的震动动画 */
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
    20%, 40%, 60%, 80% { transform: translateX(5px); }
  }
  .animate-shake {
    animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both;
  }
</style>
